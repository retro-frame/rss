; This file provides the Retro System Specification of the Intel MCS-4 Micro
; Computer Set chip family (4001, 4002, 4003 and 4004). As line multiplexing is
; used (i.e. the meaning of the current data on a bus depends on the state) and
; I/O ports are connected to a ROM, RAM or I/O chip rather than using a central
; bus, this specification uses the following virtual bus concept:
;
; - ROM/8
;
;   This bus is used for fetching data (i.e. instructions) from a ROM by read
;   events from the CPU. A 12-bit address is used and each ROM shall recognize
;   itself by the high 4 bits. The low 8 bits represent the local byte address.
;
; - SRC
;
;   This bus is used by the CPU to transmit the address for subsequent reads or
;   writes to the ROM and RAM components as write events. This bus uses 11 bits
;   to represent the address but does not transfer data. Each RAM bank shall
;   recognize itself by the high 3 bits (which are taken from the most recent
;   DCL instruction and transmitted over the CM-RAM-x lines on the actual
;   system) while the ROM components shall ignore those high bits as the ROM
;   chip is determined by the middle 4 bits (according to the SRC instruction).
;
; - ROM_PORT/4
;
;   This bus is used for ROM port transfer. It does not use an address by
;   itself as the port address (i.e. the ROM chip) has been sent in advance by
;   the SRC bus.
;
; - RAM_PORT/4
;
;   This bus is used for RAM port transfer. An 11-bit address is used where the
;   high 3 bits refer to the current RAM bank (CM-RAM-x signals) but the port
;   address (i.e. the RAM chip) has been sent in advance by the SRC bus.
;
; - MEM/4
;
;   This bus is used for RAM memory character transfer. An 11-bit address is
;   used where the high 3 bits refer to the current RAM bank (CM-RAM-x signals)
;   but the other parts of the address (i.e. chip, register and character) have
;   been sent in advance by the SRC bus.
;
; - STAT/4
;
;   This bus is used for RAM status character transfer. An 11-bit address is
;   used where the high 3 bits refer to the current RAM bank (CM-RAM-x signals)
;   and the low 2 bits refer to the status character. The other parts of the
;   address (i.e. chip and register) have been sent in advance by the SRC bus.
;
; - IO_x/1 / OUT_x/1 / IN_x/1
;
;   This buses represent by the individual I/O pins (i.e. I/O, input or output
;   lines) of ROM, RAM and I/O chips. No address is used.
;
; For further documentation of the MCS-4, including a descripton of its actual
; bus concept, see /doc/MCS-4.txt//.


;------------------------------------------------------------------------------
;
;  4001 ROM chip
;
;------------------------------------------------------------------------------


ROM "Intel 4001 256 x 8 bit ROM chip"
(
    ; buses:

    ROM/8,                          ; fetch bus
    SRC,                            ; address transmission bus
    ROM_PORT/4,                     ; ROM port read/write bus
    IO_0/1, IO_1/1, IO_2/1, IO_3/1  ; I/O lines of ROM chip
)
    ; default path to ROM file:

    ROM_FILE = "./MCS-4.ROM",

    ; I/O pin configuration:
    ; - mode value 0 represents an output line (0 is sent on read)
    ; - mode value 1 represents an output line (1 is sent on read)
    ; - any other mode value represents an input line
    ; This component translates PORT/4 reads and writes to multiple IO/1
    ; reads and writes.

    IO_0_MODE = 0 ("out line / in 0", "out line / in 1", "in line"),
    IO_1_MODE = 0 ("out line / in 0", "out line / in 1", "in line"),
    IO_2_MODE = 0 ("out line / in 0", "out line / in 1", "in line"),
    IO_3_MODE = 0 ("out line / in 0", "out line / in 1", "in line")
{
    CONST ROM_MEM/8(256) = ROM_FILE[$INSTANCE * 256].
    VAR SRC_PORT/1.

RESET:

    $CLEAR.  ; clear all ROM variables

ROM READ =UINT/4($INSTANCE)nnnnnnnn:

    ROM/8 = ROM_MEM/8(UINT/16(n)).

SRC xxxiiiinnnn:

    IF (UINT/4(i) == $INSTANCE)
    {
        SRC_PORT/1 = 1.
    }
    ELSE
    {
        SRC_PORT/1 = 0.
    }

ROM_PORT READ:

    IF (SRC_PORT/1 == 1)
    {
        ROM_PORT/4 = 0.

        IF ((IO_0_MODE == 1) || ((IO_0_MODE > 1) && (IO_0/1 != 0)))
        {
            ROM_PORT/4 |= 0x1.
        }

        IF ((IO_1_MODE == 1) || ((IO_1_MODE > 1) && (IO_1/1 != 0)))
        {
            ROM_PORT/4 |= 0x2.
        }

        IF ((IO_2_MODE == 1) || ((IO_2_MODE > 1) && (IO_2/1 != 0)))
        {
            ROM_PORT/4 |= 0x4.
        }

        IF ((IO_3_MODE == 1) || ((IO_3_MODE > 1) && (IO_3/1 != 0)))
        {
            ROM_PORT/4 |= 0x8.
        }
    }

ROM_PORT WRITE:

    IF (SRC_PORT/1 == 1)
    {
        IF (IO_0_MODE > 1)
        {
            IO_0/1 = ROM_PORT/4.
        }

        IF (IO_1_MODE > 1)
        {
            IO_1/1 = ROM_PORT/4 >> 1.
        }

        IF (IO_2_MODE > 1)
        {
            IO_2/1 = ROM_PORT/4 >> 2.
        }

        IF (IO_3_MODE > 1)
        {
            IO_3/1 = ROM_PORT/4 >> 3.
        }
    }
}


;------------------------------------------------------------------------------
;
;  4002 RAM bank (consists of 4 4002 chips)
;
;------------------------------------------------------------------------------


RAM "Intel 4002 4 x 320 bit RAM bank"
(
    ; buses:

    SRC,                                         ; address transmission bus
    MEM/4,                                       ; main memory character bus
    STAT/4,                                      ; status character bus
    RAM_PORT/4,                                  ; RAM port write bus
    OUT_0_0/1, OUT_0_1/1, OUT_0_2/1, OUT_0_3/1,  ; output lines of RAM chip 0
    OUT_1_0/1, OUT_1_1/1, OUT_1_2/1, OUT_1_3/1,  ; output lines of RAM chip 1
    OUT_2_0/1, OUT_2_1/1, OUT_2_2/1, OUT_2_3/1,  ; output lines of RAM chip 2
    OUT_3_0/1, OUT_3_1/1, OUT_3_2/1, OUT_3_3/1   ; output lines of RAM chip 3
)
{
    VAR CHIP(4)
    {
        REGISTER(4) { MAIN_CHAR/4(16), STATUS_CHAR/4(4) }
    }

    VAR ADDR { CHIP/2, REGISTER/2, CHAR/4 }

RESET:

    $CLEAR.  ; clear all RAM variables

SRC =UINT/3($INSTANCE)ccrrnnnn:

    ADDR:CHIP/2 = UINT/2(c).
    ADDR:REGISTER/2 = UINT/2(r).
    ADDR:CHAR/4 = UINT/4(n).

MEM READ =UINT/3($INSTANCE)xxxxxxxx:

    MEM/4 = CHIP(ADDR:CHIP):REGISTER(ADDR:REGISTER):MAIN_CHAR/4(ADDR:CHAR).

MEM WRITE =UINT/3($INSTANCE)xxxxxxxx:

    CHIP(ADDR:CHIP):REGISTER(ADDR:REGISTER):MAIN_CHAR/4(ADDR:CHAR) = MEM/4.

STAT READ =UINT/3($INSTANCE)xxxxxxnn:

    STAT/4 = CHIP(ADDR:CHIP):REGISTER(ADDR:REGISTER):STATUS_CHAR/4(UINT/2(n)).

STAT WRITE =UINT/3($INSTANCE)xxxxxxnn:

    CHIP(ADDR:CHIP):REGISTER(ADDR:REGISTER):STATUS_CHAR/4(UINT/2(n)) = STAT/4.

RAM_PORT WRITE =UINT/3($INSTANCE)xxxxxxxx:

    IF (ADDR:CHIP <= 1)
    {
        IF (ADDR:CHIP == 0)
        {
            OUT_0_0/1 = RAM_PORT/4.
            OUT_0_1/1 = RAM_PORT/4 >> 1.
            OUT_0_2/1 = RAM_PORT/4 >> 2.
            OUT_0_3/1 = RAM_PORT/4 >> 3.
        }
        ELSE
        {
            OUT_1_0/1 = RAM_PORT/4.
            OUT_1_1/1 = RAM_PORT/4 >> 1.
            OUT_1_2/1 = RAM_PORT/4 >> 2.
            OUT_1_3/1 = RAM_PORT/4 >> 3.
        }
    }
    ELSE
    {
        IF (ADDR:CHIP == 2)
        {
            OUT_2_0/1 = RAM_PORT/4.
            OUT_2_1/1 = RAM_PORT/4 >> 1.
            OUT_2_2/1 = RAM_PORT/4 >> 2.
            OUT_2_3/1 = RAM_PORT/4 >> 3.
        }
        ELSE
        {
            OUT_3_0/1 = RAM_PORT/4.
            OUT_3_1/1 = RAM_PORT/4 >> 1.
            OUT_3_2/1 = RAM_PORT/4 >> 2.
            OUT_3_3/1 = RAM_PORT/4 >> 3.
        }
    }
}


;------------------------------------------------------------------------------
;
;  4004 CPU
;
;------------------------------------------------------------------------------


CPU "Intel 4004 CPU"
(
    ; buses:

    ROM/8,       ; fetch bus
    SRC,         ; address transmission bus
    ROM_PORT/4,  ; ROM port read/write bus
    RAM_PORT/4,  ; RAM port write bus
    MEM/4,       ; main memory character bus
    STAT/4,      ; status character bus
    TEST/1       ; test input line of CPU chip
)
    ; default clock rate is 740 kHz (1.35 microseconds per cycle):

    CLOCK_RATE = 740
{
    ; registers:

    VAR A/4.        ; accumulator
    VAR CY/1.       ; carry flag (flip-flop)
    VAR REG/4(16).  ; 16 4-bit registers

    READ REG/8(x)
    {
        REG/8 = $VALUE(REG/4(2 * x), REG/4(2 * x + 1)).  ; high nibble first
    }

    WRITE REG/8(x)
    {
        $VALUE(REG/4(2 * x), REG/4(2 * x + 1)) = REG/8.  ; high nibble first
    }

    VAR ADDRESS_STACK/12(4).

    VAR ADDRESS_STACK_PTR/2.

    VAR RAM_BANK/3.  ; RAM bank currently selected by DCL

    PROC ADDRESS_STACK_PUSH
    {
        ADDRESS_STACK/12(ADDRESS_STACK_PTR/2) = $.

        ADDRESS_STACK_PTR/2 += 1.  ; may overflow
    }

    PROC ADDRESS_STACK_POP
    {
        ADDRESS_STACK_PTR/2 -= 1.  ; may underflow

        $ = ADDRESS_STACK/12(ADDRESS_STACK_PTR/2).
    }

RESET:

    $CYCLE_FREQ = CLOCK_RATE.

    $CLEAR.             ; clear all CPU variables
    $FETCH(ROM/8(12)).  ; 12-bit program counter, fetch from bus ROM/8

OPCODE 0000xxxx:

    ; NOP (no operation):

    IF (UINT/4(x) != 0)
    {
        $OPCODE_INVALID.
    }

    $CYCLES(8).

OPCODE 0001nact llllllll:

    ; JCN (jump conditional):

    VAR T/1.

    T/1 = 0.

    IF (UINT/1(t) && (TEST/1(0) == 0))
    {
        T/1 |= 1.  ; test signal on bus TEST/1 is zero
    }

    IF (UINT/1(c) && (CY/1 == 1))
    {
        T/1 |= 1.  ; carry flag CY is set
    }

    IF (UINT/1(a) && (A/4 == 0))
    {
        T/1 |= 1.  ; accumulator A is zero
    }

    IF ((UINT/1(n) ^ T/1) != 0)
    {
        $ = ($ & 0xF00) | UINT/8(l).  ; keep current ROM page
    }

    $CYCLES(16).

OPCODE 0010rrr0 dddddddd:

    ; FIM (fetch immediate):

    REG/8(UINT/3(r)) = UINT/8(d)

    $CYCLES(16).

OPCODE 0010rrr1:

    ; SRC (send register control):

    SRC(RAM_BANK << 8 | REG/8(UINT/3(r))).

    $CYCLES(8).

OPCODE 0011rrr0:

    ; FIN (fetch indirect):

    REG/8(UINT/3(r)) = ROM/8(($ & 0xF00) | REG/8(0)).

    $CYCLES(16).

OPCODE 0011rrr1:

    ; JIN (jump indirect):

    $ = ($ & 0xF00) | REG/8(UINT/3(r)).

    $CYCLES(8).

OPCODE 0100hhhh llllllll:

    ; JUN (jump unconditional):

    $ = UINT/4(h) << 8 | UINT/8(l).

    $CYCLES(16).

OPCODE 0101hhhh llllllll:

    ; JMS (jump subroutine):

    ADDRESS_STACK_PUSH

    $ = UINT/4(h) << 8 | UINT/8(l).

    $CYCLES(16).

OPCODE 0110rrrr:

    ; INC (increment register):

    REG/4(UINT/4(r)) += 1.  ; may overflow

    $CYCLES(8).

OPCODE 0111rrrr llllllll:

    ; ISZ (increment register and skip):

    REG/4(UINT/4(r)) += 1.  ; may overflow

    IF (REG/4(UINT/4(r)) == 0)
    {
        $ = ($ & 0xF00) | UINT/8(l).  ; keep current ROM page
    }

    $CYCLES(16).

OPCODE 1000rrrr:

    ; ADD (add register with carry):

    A/4 += REG/4(UINT/4(r)) + CY/1.

    CY/1 = $FLAGS:CARRY.

    $CYCLES(8).

OPCODE 1001rrrr:

    ; SUB (subtract register with borrow):

    A/4 += ~REG/4(UINT/4(r)) + (CY/1 ^ 1).

    CY/1 = $FLAGS:CARRY.

    $CYCLES(8).

OPCODE 1010rrrr:

    ; LD (load accumulator from register):

    A/4 = REG/4(UINT/4(r)).

    $CYCLES(8).

OPCODE 1011rrrr:

    ; XCH (exchange accumulator with register):

    A/4 <> REG/4(UINT/4(r)).

    $CYCLES(8).

OPCODE 1100dddd:

    ; BBL (branch back and load accumulator):

    ADDRESS_STACK_POP.

    A/4 = UINT/4(d).

    $CYCLES(8).

OPCODE 1101dddd:

    ; LDM (load accumulator):

    A/4 = UINT/4(d).

    $CYCLES(8).

OPCODE 11100000:

    ; WRM (write accumulator to main memory):

    MEM/4(RAM_BANK/3 << 8) = A/4.

    $CYCLES(8).

OPCODE 11100001:

    ; WMP (write accumulator to RAM port):

    RAM_PORT/4(RAM_BANK/3 << 8) = A/4.

    $CYCLES(8).

OPCODE 11100010:

    ; WRR (write accumulator to ROM port):

    ROM_PORT/4 = A/4.

    $CYCLES(8).

OPCODE 111001ss:

    ; WRx (write accumulator to status char #x):

    STAT/4((RAM_BANK/3 << 8) | UINT/2(s)) = A/4.

    $CYCLES(8).

OPCODE 11101000:

    ; SBM (subtract main memory with borrow):

    A/4 += ~MEM/4(RAM_BANK/3 << 8) + (CY/1 ^ 1).

    CY/1 = $FLAGS:CARRY.

    $CYCLES(8).

OPCODE 11101001:

    ; RDM (read accumulator from main memory):

    A/4 = MEM/4(RAM_BANK/3 << 8).

    $CYCLES(8).

OPCODE 11101010:

    ; RDR (read accumulator from ROM port):

    A/4 = ROM_PORT/4.

    $CYCLES(8).

OPCODE 11101011:

    ; ADM (add main memory with carry):

    A/4 += MEM/4(RAM_BANK/3 << 8) + CY/1.

    CY/1 = $FLAGS:CARRY.

    $CYCLES(8).

OPCODE 111011ss:

    ; RDx (read accumulator from status char #):

    A/4 = STAT/4((RAM_BANK/3 << 8) | UINT/2(s)).

    $CYCLES(8).

OPCODE 11110000:

    ; CLB (clear accumulator and carry):

    A/4 = 0.
    CY/1 = 0.

    $CYCLES(8).

OPCODE 11110001:

    ; CLC (clear carry):

    CY/1 = 0.

    $CYCLES(8).

OPCODE 11110010:

    ; IAC (increment accumulator):

    A/4 += 1.

    CY/1 = $FLAGS:CARRY.

    $CYCLES(8).

OPCODE 11110011:

    ; CMC (complement carry):

    CY/1 = ~CY/1.

    $CYCLES(8).

OPCODE 11110100:

    ; CMA (complement accumulator):

    A/4 = ~A/4.

    $CYCLES(8).

OPCODE 11110101:

    ; RAL (rotate accumulator left):

    A/4 <<<= 1.  ; rotate without carry

    CY/1 ^= A/4.  ; swap least significand bit with carry
    A/4 ^= CY/1.
    CY/1 ^= A/4.

    $CYCLES(8).

OPCODE 11110110:

    ; RAR (rotate accumulator right):

    CY/1 ^= A/4.  ; swap least significand bit with carry
    A/4 ^= CY/1.
    CY/1 ^= A/4.

    A/4 >>>= 1.  ; rotate without carry

    $CYCLES(8).

OPCODE 11110111:

    ; TCC (transfer carry and clear):

    A/4 = CY/1.
    CY/1 = 0.

    $CYCLES(8).

OPCODE 11111000:

    ; DAC (decrement accumulator):

    A/4 += 0xF.

    CY/1 = $FLAGS:CARRY.

    $CYCLES(8).

OPCODE 11111001:

    ; TCS (transfer carry substract):

    IF (CY/1 == 0)
    {
        A/4 = 9.
    }
    ELSE
    {
        A/4 = 10.
    }

    CY/1 = 0.

    $CYCLES(8).

OPCODE 11111010:

    ; STC (set carry):

    CY/1 = 1.

    $CYCLES(8).

OPCODE 11111011:

    ; DAA (decimal adjust accumulator):

    IF ((CY/1 == 1) || (A/4 > 9))
    {
        A/4 += 6.

        CY/1 = $FLAGS:CARRY.
    }

    $CYCLES(8).

OPCODE 11111100:

    ; KBP (keyboard process):

    IF (A/4 == 0x4)
    {
        A/4 = 0x3.
    }
    ELIF (A/4 == 0x8)
    {
        A/4 = 0x4.
    }
    ELIF (A/4 > 2)
    {
        A/4 = 0xF.
    }

    $CYCLES(8).

OPCODE 11111101:

    ; DCL (designate command line):

    RAM_BANK/3 = A/4.

    $CYCLES(8).

OPCODE 1111111x:

    $OPCODE_INVALID.
    $CYCLES(8).
}
