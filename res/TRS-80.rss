IMPORT "./Z80.rss".  ; include Z80 CPU specification


;------------------------------------------------------------------------------
;
;  TRS-80 Model I Level I generic 4K ROM
;  (ROM contents is read from file)
;
;------------------------------------------------------------------------------


ROM "TRS-80 Model I Level I ROM"
(
    MEM/8  ; data bus
)  
    ROM_FILE = "./TRS-80/L1_ROM.bin"  ; default path to ROM file
{
    CONST DATA/8(0x1000) = ROM_FILE.

MEM READ 0000nnnnnnnnnnnn:

    MEM/8 = DATA/8(UINT/16(n)).
}


;------------------------------------------------------------------------------
;
;  TRS-80 Model I generic 4K / 8K / 16K RAM variants
;  (16K RAM may have up to 3 instances to support 16K, 32K and 48K)
;
;------------------------------------------------------------------------------


RAM "TRS-80 Model I 4K RAM"
(
    MEM/8  ; data bus
)
{
    VAR DATA/8(0x1000).

RESET:

    $CLEAR.  ; clear RAM

MEM READ 0100nnnnnnnnnnnn:

    MEM/8 = DATA/8(UINT/16(n)).

MEM WRITE 0100nnnnnnnnnnnn:

    DATA/8(UINT/16(n)) = MEM/8.
}


RAM "TRS-80 Model I 8K RAM"
(
    MEM/8  ; data bus
)
{
    VAR DATA/8(0x2000).

RESET:

    $CLEAR.  ; clear RAM

MEM READ 010nnnnnnnnnnnnn:

    MEM/8 = DATA/8(UINT/16(n)).

MEM WRITE 010nnnnnnnnnnnnn:

    DATA/8(UINT/16(n)) = MEM/8.
}


RAM "TRS-80 Model I 16K RAM"
(
    MEM/8  ; data bus
)
{
    VAR DATA/8(0x4000).

RESET:

    $CLEAR.  ; clear RAM

MEM READ =UINT/2($INSTANCE + 1)nnnnnnnnnnnnnn:

    MEM/8 = DATA/8(UINT/16(n)).

MEM WRITE =UINT/2($INSTANCE + 1)nnnnnnnnnnnnnn:

    DATA/8(UINT/16(n)) = MEM/8.
}


;------------------------------------------------------------------------------
;
;  TRS-80 Model I memory-mapped keyboard with 53 keys
;
;------------------------------------------------------------------------------


KEYBOARD "TRS-80 Model I Keyboard (53 Keys)"
(
    MEM/8  ; data bus
)
{
    ; TRS-80 Model I polls for keys so we have to keep track of the key states:

    VAR KEY_STATE/8(8).

    ; key specification:

    $KEY(0x00, '@').
    $KEY(0x01, 'A', 'a').
    $KEY(0x02, 'B', 'b').
    $KEY(0x03, 'C', 'c').
    $KEY(0x04, 'D', 'd').
    $KEY(0x05, 'E', 'e').
    $KEY(0x06, 'F', 'f').
    $KEY(0x07, 'G', 'g').
    $KEY(0x10, 'H', 'h').
    $KEY(0x11, 'I', 'i').
    $KEY(0x12, 'J', 'j').
    $KEY(0x13, 'K', 'k').
    $KEY(0x14, 'L', 'l').
    $KEY(0x15, 'M', 'm').
    $KEY(0x16, 'N', 'n').
    $KEY(0x17, 'O', 'o').
    $KEY(0x20, 'P', 'p').
    $KEY(0x21, 'Q', 'q').
    $KEY(0x22, 'R', 'r').
    $KEY(0x23, 'S', 's').
    $KEY(0x24, 'T', 't').
    $KEY(0x25, 'U', 'u').
    $KEY(0x26, 'V', 'v').
    $KEY(0x27, 'W', 'w').
    $KEY(0x30, 'X', 'x').
    $KEY(0x31, 'Y', 'y').
    $KEY(0x32, 'Z', 'z').

    $KEY(0x40, '0').
    $KEY(0x41, '1', MODIFIED('!', 0x70)).
    $KEY(0x42, '2', MODIFIED('\"', 0x70)).
    $KEY(0x43, '3', MODIFIED('#', 0x70)).
    $KEY(0x44, '4', MODIFIED('$', 0x70)).
    $KEY(0x45, '5', MODIFIED('%', 0x70)).
    $KEY(0x46, '6', MODIFIED('&', 0x70)).
    $KEY(0x47, '7', MODIFIED('\'', 0x70)).
    $KEY(0x50, '8', MODIFIED('(', 0x70)).
    $KEY(0x51, '9', MODIFIED(')', 0x70)).
    $KEY(0x52, ':', MODIFIED('*', 0x70)).
    $KEY(0x53, ';', MODIFIED('+', 0x70)).
    $KEY(0x54, ',', MODIFIED('<', 0x70)).
    $KEY(0x55, '-', MODIFIED('=', 0x70)).
    $KEY(0x56, '.', MODIFIED('>', 0x70)).
    $KEY(0x57, '/', MODIFIED('?', 0x70)).

    $KEY(0x60, RETURN, ENTER).
    $KEY(0x61, CLEAR).
    $KEY(0x62, CANCEL).
    $KEY(0x63, CURSOR_UP, NUMPAD_UP).
    $KEY(0x64, CURSOR_DOWN, NUMPAD_DOWN).
    $KEY(0x65, CURSOR_LEFT, NUMPAD_LEFT, BACKSPACE).
    $KEY(0x66, CURSOR_RIGHT, NUMPAD_RIGHT).
    $KEY(0x67, SPACE).

    $KEY_MODIFIER(0x70, L_SHIFT, R_SHIFT).

    ; keyboard layout and graphics:

    $KEYBOARD_LAYOUT(
        "  +---+---+---+---+---+---+---+---+---+---+---+---+---+",
        "  | 41| 42| 43| 44| 45| 46| 47| 50| 51| 40| 52| 55| 62|",
        "+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+",
        "| 63| 21| 27| 05| 22| 24| 31| 25| 11| 17| 20| 00| 65| 66|",
        "+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+---+-+-+-+",
        "  | 64| 01| 23| 04| 06| 07| 10| 12| 13| 14| 53|   60  | 61|",
        "  +---+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-----+-+-+",
        "  |  70 | 32| 30| 03| 26| 02| 16| 15| 54| 56| 57|  70 |",
        "  +-----+---+---+---+---+---+---+---+---+---+---+-----+",
        "            |               67              |",
        "            +-------------------------------+").

    $KEYBOARD = "./TRS-80/M1_KBD0.png"
    $KEYBOARD_PRESSED = "./TRS-80/M1_KBD1.png"

RESET:

    $CLEAR.  ; clear key states

KEY PRESSED 0aaa0ddd:

    ; aaa represents address line, ddd data line:

    KEY_STATE(UINT/3(a)) |= 1 << UINT/3(d).

KEY RELEASED 0aaa0ddd:

    ; aaa represents address line, ddd data line:

    KEY_STATE(UINT/3(a)) &= ~(1 << UINT/3(d)).

MEM READ 11100000000001:

    MEM/8 = KEY_STATE(0).  ; address 0x3801 == 14337

MEM READ 11100000000010:

    MEM/8 = KEY_STATE(1).  ; address 0x3802 == 14338

MEM READ 11100000000100:

    MEM/8 = KEY_STATE(2).  ; address 0x3804 == 14340

MEM READ 11100000001000:

    MEM/8 = KEY_STATE(3).  ; address 0x3808 == 14344

MEM READ 11100000010000:

    MEM/8 = KEY_STATE(4).  ; address 0x3810 == 14352

MEM READ 11100000100000:

    MEM/8 = KEY_STATE(5).  ; address 0x3820 == 14368

MEM READ 11100001000000:

    MEM/8 = KEY_STATE(6).  ; address 0x3840 == 14400

MEM READ 11100010000000:

    MEM/8 = KEY_STATE(7).  ; address 0x3880 == 14464
}


;------------------------------------------------------------------------------
;
;  TRS-80 Model I memory-mapped screen with 1KB video memory
;
;------------------------------------------------------------------------------


SCREEN "TRS-80 Model I Video"
(
    MEM/8  ; data bus
)
{
    ; video RAM:

    VAR ROW(16)
    {
        COL/8(64)
    }

RESET:

    $CLEAR.  ; clear video RAM

    ; default text output is 64 x 16 characters white on black:

    $SCREEN_TEXT(64, 16, 0xFFFFFF, 0x000000).

    ; default graphics output is 128 x 48 pixels white on black:

    $SCREEN_TEXT(128, 48, 0xFFFFFF, 0x000000).

MEM READ 001111rrrrcccccc:

    MEM/8 = ROW(UINT/4(r)):COL/8(UINT/6(c)).

MEM WRITE 001111rrrrcccccc:

    ROW(UINT/4(r)):COL/8(UINT/6(c)) = MEM/8.

    IF (MEM/8 < 0x80)
    {
        ; text output (pixels, if present, will be overwritten):

        $SCREEN_CHAR/8(UINT/4(r), UINT/6(c)) = MEM/8.
    }
    ELSE
    {
        ; graphics output (characters, if present, will be overwritten):

        VAR X/8.
        VAR Y/8.

        X/8 = UINT/6(c) * 2.
        Y/8 = UINT/4(r) * 3.

        $SCREEN_PIXEL/1(X/8 + 0, Y/8 + 0) = MEM/8 & 0x01.
        $SCREEN_PIXEL/1(X/8 + 1, Y/8 + 0) = (MEM/8 >> 1) & 0x01.
        $SCREEN_PIXEL/1(X/8 + 0, Y/8 + 1) = (MEM/8 >> 2) & 0x01.
        $SCREEN_PIXEL/1(X/8 + 1, Y/8 + 1) = (MEM/8 >> 3) & 0x01.
        $SCREEN_PIXEL/1(X/8 + 0, Y/8 + 2) = (MEM/8 >> 4) & 0x01.
        $SCREEN_PIXEL/1(X/8 + 1, Y/8 + 2) = (MEM/8 >> 5) & 0x01.
    }
}


;------------------------------------------------------------------------------
;
;  TRS-80 Model I Level I generic system with selectable RAM
;
;------------------------------------------------------------------------------


SYSTEM "TRS-80 Model I Level I"

    RAM_SIZE = 0 ("4K", "8K", "16K)  ; default RAM size is 4K
{
    ROM "TRS-80 Model I Level I ROM" (MEM/8).

    IF (RAM_SIZE == 0)
    {
        RAM "TRS-80 Model I 4K RAM" (MEM/8).
    }
    ELIF (RAM_SIZE == 1)
    {
        RAM "TRS-80 Model I 8K RAM" (MEM/8).
    }
    ELSE
    {
        RAM "TRS-80 Model I 16K RAM" (MEM/8).
    }

    CPU "Z80" (MEM/8, -, -).

    KEYBOARD "TRS-80 Model I Keyboard (53 Keys)" (MEM/8).
    SCREEN "TRS-80 Model I Video" (MEM/8).
}
